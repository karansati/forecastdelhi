# Copy to .env and fill in (used for LOCAL runs only).
OPENWEATHER_API_KEY=your_openweather_api_key_here
# Either paste the whole service-account JSON on one line:
FIREBASE_CREDENTIALS_JSON=
# ...or point to a file (default: serviceAccount.json in the project root):
FIREBASE_CREDENTIALS_FILE=serviceAccount.json
# Optional overrides:
DELHI_LAT=28.6139
DELHI_LON=77.2090
MODEL_PATH=artifacts/model.joblib
